---
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: 'tr' | 'en';
}
const { lang } = Astro.props;
const t = useTranslations(lang);
const isTr = lang === 'tr';
---

<form id="contact-form" novalidate>

  <div class="form-group">
    <label for="cf-name">{isTr ? 'Adınız Soyadınız' : 'Full Name'}</label>
    <input type="text" id="cf-name" name="name" required autocomplete="name" />
    <span class="field-error" id="name-error"></span>
  </div>

  <div class="form-group">
    <label for="cf-email">{isTr ? 'E-posta Adresiniz' : 'Email Address'}</label>
    <input type="email" id="cf-email" name="email" required autocomplete="email" />
    <span class="field-error" id="email-error"></span>
  </div>

  <div class="form-group">
    <label for="cf-phone">{isTr ? 'Telefon Numarası' : 'Phone Number'}</label>
    <input type="tel" id="cf-phone" name="phone" required autocomplete="tel" inputmode="numeric" />
    <span class="field-error" id="phone-error"></span>
  </div>

  <div class="form-group">
    <label for="cf-subject">{isTr ? 'Konu' : 'Subject'}</label>
    <input type="text" id="cf-subject" name="subject" required />
    <span class="field-error" id="subject-error"></span>
  </div>

  <div class="form-group">
    <label for="cf-message">{isTr ? 'Mesajınız' : 'Your Message'}</label>
    <textarea id="cf-message" name="message" required></textarea>
    <span class="field-error" id="message-error"></span>
  </div>

  <div id="form-status" class="form-status"></div>

  <button type="submit" class="btn-primary contact-submit">
    {isTr ? 'Gönder' : 'Send'}
  </button>

</form>

<style>
  form { display: flex; flex-direction: column; }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    margin-bottom: 1.25rem;
  }

  label {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text-muted);
  }

  input, textarea {
    width: 100%;
    background: var(--color-bg-2);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    color: var(--color-text);
    padding: 0.75rem 1rem;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.95rem;
    transition: border-color var(--transition);
  }

  input:focus, textarea:focus {
    outline: none;
    border-color: var(--color-teal);
    box-shadow: 0 0 0 3px rgba(0, 200, 200, 0.12);
  }

  textarea { min-height: 160px; resize: vertical; }

  .field-error {
    font-size: 0.78rem;
    color: #f87171;
    min-height: 1rem;
    display: block;
  }

  .form-status {
    font-size: 0.9rem;
    margin-bottom: 1rem;
    min-height: 1.5rem;
  }
  .form-status.success { color: var(--color-teal); }
  .form-status.error   { color: #f87171; }

  .contact-submit { align-self: flex-start; }
</style>

<script define:vars={{ isTr }}>
  const form   = document.getElementById('contact-form');
  const status = document.getElementById('form-status');

  const errMsgs = {
    name:    { empty: isTr ? 'Ad soyad gereklidir.' : 'Full name is required.' },
    email:   { empty: isTr ? 'E-posta adresi gereklidir.' : 'Email is required.',
               invalid: isTr ? 'Geçerli bir e-posta adresi giriniz.' : 'Please enter a valid email address.' },
    phone:   { empty: isTr ? 'Telefon numarası gereklidir.' : 'Phone number is required.',
               invalid: isTr ? 'Geçerli bir telefon numarası giriniz (sadece rakam, en az 10 hane).' : 'Please enter a valid phone number (numbers only, min 10 digits).' },
    subject: { empty: isTr ? 'Konu gereklidir.' : 'Subject is required.' },
    message: { empty: isTr ? 'Mesaj gereklidir.' : 'Message is required.' },
  };

  function setError(id, msg) {
    const el = document.getElementById(id + '-error');
    if (el) el.textContent = msg;
  }

  function clearErrors() {
    ['name','email','phone','subject','message'].forEach(f => setError(f, ''));
  }

  function validate(d) {
    let ok = true;
    if (!d.name)    { setError('name',    errMsgs.name.empty);    ok = false; }
    if (!d.email)   { setError('email',   errMsgs.email.empty);   ok = false; }
    else if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(d.email)) { setError('email', errMsgs.email.invalid); ok = false; }
    if (!d.phone)   { setError('phone',   errMsgs.phone.empty);   ok = false; }
    else if (!/^\d{10,}$/.test(d.phone)) { setError('phone', errMsgs.phone.invalid); ok = false; }
    if (!d.subject) { setError('subject', errMsgs.subject.empty); ok = false; }
    if (!d.message) { setError('message', errMsgs.message.empty); ok = false; }
    return ok;
  }

  document.getElementById('cf-phone')?.addEventListener('input', (e) => {
    e.target.value = e.target.value.replace(/\D/g, '');
  });

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    clearErrors();
    status.textContent = '';
    status.className = 'form-status';

    const fd = new FormData(form);
    const d = {
      name:    fd.get('name')?.toString().trim()    ?? '',
      email:   fd.get('email')?.toString().trim()   ?? '',
      phone:   fd.get('phone')?.toString().trim()   ?? '',
      subject: fd.get('subject')?.toString().trim() ?? '',
      message: fd.get('message')?.toString().trim() ?? '',
    };

    if (!validate(d)) return;

    const btn = form.querySelector('button[type="submit"]');
    btn.disabled = true;
    btn.textContent = isTr ? 'Gönderiliyor...' : 'Sending...';

    try {
      const res  = await fetch('/api/contact', { method: 'POST', body: fd });
      const json = await res.json();
      if (json.ok) {
        status.textContent = isTr
          ? 'Mesajınız iletildi. En kısa sürede size dönüş yapacağız.'
          : 'Your message has been sent. We will get back to you shortly.';
        status.className = 'form-status success';
        form.reset();
      } else {
        throw new Error(json.error);
      }
    } catch {
      status.textContent = isTr
        ? 'Bir hata oluştu. Lütfen tekrar deneyin.'
        : 'An error occurred. Please try again.';
      status.className = 'form-status error';
    } finally {
      btn.disabled = false;
      btn.textContent = isTr ? 'Gönder' : 'Send';
    }
  });
</script>
