---
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: 'tr' | 'en';
}
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<form class="contact-form" id="contact-form" novalidate>
  <div class="form-row">
    <div class="form-group">
      <label for="cf-name">{t('contact.name')}</label>
      <input type="text" id="cf-name" name="name" autocomplete="name" required placeholder={t('contact.name')} />
    </div>
    <div class="form-group">
      <label for="cf-email">{t('contact.email')}</label>
      <input type="email" id="cf-email" name="email" autocomplete="email" required placeholder={t('contact.email')} />
    </div>
  </div>

  <div class="form-group">
    <label for="cf-subject">{t('contact.subject')}</label>
    <input type="text" id="cf-subject" name="subject" required placeholder={t('contact.subject')} />
  </div>

  <div class="form-group">
    <label for="cf-message">{t('contact.message')}</label>
    <textarea id="cf-message" name="message" required placeholder={t('contact.message')}></textarea>
  </div>

  <div class="form-footer">
    <button type="submit" class="btn-primary contact-form__submit">
      <span class="submit-text">{t('contact.send')}</span>
      <svg class="submit-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/>
      </svg>
      <svg class="submit-spinner" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
        <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/>
      </svg>
    </button>
  </div>

  <div class="form-status" id="form-status" role="alert" aria-live="polite" hidden>
    <span class="form-status__icon" aria-hidden="true"></span>
    <span class="form-status__text"></span>
  </div>
</form>

<script define:vars={{ successMsg: t('contact.success'), errorMsg: t('contact.error') }}>
  const form = document.getElementById('contact-form');
  const status = document.getElementById('form-status');
  const statusText = status?.querySelector('.form-status__text');
  const statusIcon = status?.querySelector('.form-status__icon');
  const submitBtn = form?.querySelector('.contact-form__submit');

  function showStatus(ok, msg) {
    if (!status || !statusText || !statusIcon) return;
    status.removeAttribute('hidden');
    status.className = `form-status form-status--${ok ? 'success' : 'error'}`;
    statusIcon.textContent = ok ? '✓' : '✕';
    statusText.textContent = msg;
  }

  function setLoading(loading) {
    if (!submitBtn) return;
    submitBtn.disabled = loading;
    submitBtn.classList.toggle('loading', loading);
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = new FormData(form);
    const name    = data.get('name')?.toString().trim();
    const email   = data.get('email')?.toString().trim();
    const subject = data.get('subject')?.toString().trim();
    const message = data.get('message')?.toString().trim();

    if (!name || !email || !subject || !message) { showStatus(false, errorMsg); return; }
    if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) { showStatus(false, errorMsg); return; }

    setLoading(true);
    try {
      const res  = await fetch('/api/contact', { method: 'POST', body: data });
      const json = await res.json();
      if (json.ok) { showStatus(true, successMsg); form.reset(); }
      else         { showStatus(false, errorMsg); }
    } catch { showStatus(false, errorMsg); }
    finally  { setLoading(false); }
  });
</script>

<style>
  .contact-form { display: flex; flex-direction: column; gap: 1.25rem; }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }

  .form-group { display: flex; flex-direction: column; gap: 0.4rem; }

  label {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-text-muted);
    letter-spacing: 0.02em;
  }

  .form-footer { display: flex; justify-content: flex-end; }

  .contact-form__submit { position: relative; min-width: 140px; }
  .submit-spinner { display: none; animation: spin 0.8s linear infinite; }
  .contact-form__submit.loading .submit-icon    { display: none; }
  .contact-form__submit.loading .submit-spinner { display: block; }
  .contact-form__submit:disabled { opacity: 0.7; cursor: not-allowed; transform: none !important; }

  @keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }

  .form-status {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.875rem 1rem;
    border-radius: var(--radius-sm);
    font-size: 0.92rem;
    border: 1px solid;
  }
  .form-status--success { background: rgba(0,200,200,0.08); border-color: rgba(0,200,200,0.3); color: var(--color-teal); }
  .form-status--error   { background: rgba(239,68,68,0.08);  border-color: rgba(239,68,68,0.3);  color: #f87171; }
  .form-status__icon    { font-weight: 700; flex-shrink: 0; }

  @media (max-width: 600px) {
    .form-row { grid-template-columns: 1fr; }
    .form-footer { justify-content: stretch; }
    .contact-form__submit { width: 100%; justify-content: center; }
  }
</style>
