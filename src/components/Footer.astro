---
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: 'tr' | 'en';
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const navLinks =
  lang === 'tr'
    ? [
        { href: `/${lang}/`,           label: t('nav.home') },
        { href: `/${lang}/hakkimizda`, label: t('nav.about') },
        { href: `/${lang}/hizmetler`,  label: t('nav.services') },
        { href: `/${lang}/cozumler`,   label: t('nav.solutions') },
        { href: `/${lang}/urunler`,    label: t('nav.products') },
        { href: `/${lang}/ortaklar`,   label: t('nav.partners') },
        { href: `/${lang}/iletisim`,   label: t('nav.contact') },
      ]
    : [
        { href: `/${lang}/`,           label: t('nav.home') },
        { href: `/${lang}/about`,      label: t('nav.about') },
        { href: `/${lang}/services`,   label: t('nav.services') },
        { href: `/${lang}/solutions`,  label: t('nav.solutions') },
        { href: `/${lang}/products`,   label: t('nav.products') },
        { href: `/${lang}/partners`,   label: t('nav.partners') },
        { href: `/${lang}/contact`,    label: t('nav.contact') },
      ];
---

<footer class="footer">
  <div class="footer__inner container">
    <!-- Col 1: Logo + tagline -->
    <div class="footer__brand">
      <a href={`/${lang}/`} aria-label="GİTA Teknoloji">
        <img src="/logo.png" alt="GİTA Teknoloji" class="logo-img" width="140" height="42" />
      </a>
      <p class="footer__tagline">{t('footer.tagline')}</p>
    </div>

    <!-- Col 2: Nav links -->
    <nav class="footer__nav" aria-label={lang === 'tr' ? 'Footer navigasyon' : 'Footer navigation'}>
      {navLinks.map(link => (
        <a href={link.href} class="footer__nav-link">{link.label}</a>
      ))}
    </nav>

    <!-- Col 3: Contact -->
    <div class="footer__contact">
      <p class="footer__contact-label">{t('contact.email_label')}</p>
      <a href={`mailto:${t('footer.email')}`} class="footer__email">{t('footer.email')}</a>
    </div>
  </div>

  <div class="footer__bottom">
    <div class="container footer__bottom-inner">
      <span>{t('footer.rights')}</span>
      <span class="footer__bottom-email">
        <a href={`mailto:${t('footer.email')}`}>{t('footer.email')}</a>
      </span>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-bg-2);
    border-top: 1px solid var(--color-border);
    margin-top: auto;
  }

  .footer__inner {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 3rem;
    padding-top: 4rem;
    padding-bottom: 3rem;
  }

  /* Brand */
  .footer__brand { display: flex; flex-direction: column; gap: 1rem; }
  .logo-img { height: 42px; width: auto; mix-blend-mode: screen; }
  .footer__tagline {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    line-height: 1.5;
    max-width: 28ch;
  }

  /* Nav */
  .footer__nav {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .footer__nav-link {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    transition: color var(--transition);
    width: fit-content;
  }
  .footer__nav-link:hover { color: var(--color-teal); }

  /* Contact */
  .footer__contact { display: flex; flex-direction: column; gap: 0.5rem; }
  .footer__contact-label {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-teal);
  }
  .footer__email {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    transition: color var(--transition);
    word-break: break-all;
  }
  .footer__email:hover { color: var(--color-teal); }

  /* Bottom bar */
  .footer__bottom {
    border-top: 1px solid var(--color-border);
    padding: 1.25rem 0;
  }
  .footer__bottom-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    font-size: 0.82rem;
    color: var(--color-text-muted);
  }
  .footer__bottom-inner a { color: var(--color-text-muted); }
  .footer__bottom-inner a:hover { color: var(--color-teal); }

  @media (max-width: 768px) {
    .footer__inner {
      grid-template-columns: 1fr;
      gap: 2rem;
      padding-top: 3rem;
    }
    .footer__bottom-inner { flex-direction: column; align-items: flex-start; gap: 0.4rem; }
    .footer__bottom-email { display: none; }
  }
</style>
