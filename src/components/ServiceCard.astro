---
interface Props {
  icon: string;
  title: string;
  description: string;
  href?: string;
  image?: string;
}
const { icon, title, description, href, image } = Astro.props;
const Tag = href ? 'a' : 'div';
---

<Tag href={href} class={`service-card${href ? ' service-card--link' : ''}`}>
  {image && <img src={image} alt={title} class="service-card__img" loading="lazy" />}
  <span class="service-card__accent" aria-hidden="true"></span>
  <div class="service-card__icon" aria-hidden="true" set:html={icon} />
  <h3 class="service-card__title">{title}</h3>
  <p class="service-card__desc">{description}</p>
  {href && (
    <span class="service-card__arrow" aria-hidden="true">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M5 12h14M12 5l7 7-7 7"/>
      </svg>
    </span>
  )}
</Tag>

<style>
  .service-card {
    position: relative;
    background: var(--color-bg-2);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 2rem;
    overflow: hidden;
    transition: transform var(--transition), box-shadow var(--transition), border-color var(--transition);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    color: var(--color-text);
    text-decoration: none;
  }

  .service-card--link { cursor: pointer; }

  .service-card__img {
    width: calc(100% + 4rem);
    margin: -2rem -2rem 0.5rem;
    aspect-ratio: 4/3;
    object-fit: cover;
    border-radius: var(--radius-md) var(--radius-md) 0 0;
  }

  .service-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 0 32px var(--color-glow);
    border-color: rgba(0, 200, 200, 0.3);
  }

  /* Top teal accent bar */
  .service-card__accent {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--color-teal), var(--color-blue));
    border-radius: var(--radius-md) var(--radius-md) 0 0;
  }

  .service-card__icon {
    width: 40px;
    height: 40px;
    color: var(--color-teal);
    flex-shrink: 0;
  }
  .service-card__icon :global(svg) { width: 100%; height: 100%; }

  .service-card__title {
    font-size: 1.1rem;
    color: var(--color-text);
    margin: 0;
  }

  .service-card__desc {
    color: var(--color-text-muted);
    font-size: 0.92rem;
    line-height: 1.65;
    flex: 1;
  }

  .service-card__arrow {
    display: flex;
    align-items: center;
    color: var(--color-teal);
    margin-top: 0.5rem;
    transition: transform var(--transition);
  }
  .service-card:hover .service-card__arrow { transform: translateX(4px); }
</style>
