---
interface Partner {
  name: string;
  logo: string;
  mono?: boolean; // true = Simple Icons white SVG, false = colour logo
}
interface Props {
  partners: Partner[];
}
const { partners } = Astro.props;
---

<div class="partner-grid">
  {partners.map(p => (
    <div class="partner-tile" title={p.name}>
      <img
        src={p.logo}
        alt={p.name}
        class={`partner-logo${p.mono !== false ? ' partner-logo--mono' : ' partner-logo--color'}`}
        loading="lazy"
        width="120"
        height="40"
      />
    </div>
  ))}
</div>

<style>
  .partner-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    gap: 1rem;
  }

  .partner-tile {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.25rem 1rem;
    background: var(--color-bg-2);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    transition: border-color var(--transition), box-shadow var(--transition), transform var(--transition);
    min-height: 72px;
  }

  .partner-tile:hover {
    border-color: var(--color-teal);
    box-shadow: 0 0 20px var(--color-glow);
    transform: translateY(-2px);
  }

  .partner-logo {
    display: block;
    max-width: 110px;
    max-height: 40px;
    width: auto;
    height: auto;
    object-fit: contain;
    transition: opacity var(--transition);
  }

  /* Simple Icons: white SVGs, dim slightly at rest */
  .partner-logo--mono {
    opacity: 0.65;
    filter: brightness(0) invert(1);
  }
  .partner-tile:hover .partner-logo--mono {
    opacity: 1;
  }

  /* Colour logos: slightly dimmed on dark bg */
  .partner-logo--color {
    opacity: 0.80;
  }
  .partner-tile:hover .partner-logo--color {
    opacity: 1;
  }

  @media (max-width: 480px) {
    .partner-grid { grid-template-columns: repeat(auto-fill, minmax(120px, 1fr)); }
  }
</style>
