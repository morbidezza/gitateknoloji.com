---
interface Props {
  name: string;
  tagline: string;
  description: string;
  features: string[];
  cta: string;
  ctaHref: string;
}
const { name, tagline, description, features, cta, ctaHref } = Astro.props;
---

<article class="product-card reveal">
  <div class="product-card__text">
    <span class="section-label">{name}</span>
    <h3 class="product-card__tagline">{tagline}</h3>
    <p class="product-card__desc">{description}</p>
    <a href={ctaHref} class="btn-outline product-card__cta">{cta}</a>
  </div>

  <div class="product-card__features">
    <ul class="product-card__list">
      {features.map(f => (
        <li class="product-card__feature">
          <span class="product-card__chip" aria-hidden="true">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
          </span>
          <span>{f}</span>
        </li>
      ))}
    </ul>
  </div>
</article>

<style>
  .product-card {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
    background: var(--color-bg-2);
    border: 1px solid var(--color-border);
    border-left: 4px solid var(--color-teal);
    border-radius: var(--radius-md);
    padding: 2.5rem;
    transition: box-shadow var(--transition), border-color var(--transition);
  }

  .product-card:hover {
    box-shadow: 0 0 40px var(--color-glow);
    border-color: rgba(0, 200, 200, 0.35);
    border-left-color: var(--color-teal);
  }

  .product-card__tagline {
    font-size: clamp(1.2rem, 2.5vw, 1.5rem);
    margin: 0.5rem 0 1rem;
  }

  .product-card__desc {
    color: var(--color-text-muted);
    font-size: 0.93rem;
    line-height: 1.7;
    margin-bottom: 1.75rem;
  }

  .product-card__cta { align-self: flex-start; }

  /* Features panel */
  .product-card__features {
    background: var(--color-bg-3);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: 1.75rem;
  }

  .product-card__list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  .product-card__feature {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  .product-card__chip {
    color: var(--color-teal);
    flex-shrink: 0;
    margin-top: 2px;
  }

  @media (max-width: 768px) {
    .product-card {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }
</style>
