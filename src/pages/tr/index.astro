---
export const prerender = true;
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import HeroSection from '../../components/HeroSection.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import SolutionCard from '../../components/SolutionCard.astro';
import PartnerGrid from '../../components/PartnerGrid.astro';
import { useTranslations } from '../../i18n/utils';

const lang = 'tr';
const t = useTranslations(lang);
const currentPath = Astro.url.pathname;

const SI = (slug: string) => `https://cdn.simpleicons.org/${slug}/ffffff`;
const partners = [
  { name: 'HPE',        logo: SI('hewlettpackardenterprise') },
  { name: 'Dell',       logo: SI('dell') },
  { name: 'IBM',        logo: SI('ibm') },
  { name: 'Cisco',      logo: SI('cisco') },
  { name: 'Juniper',    logo: SI('junipernetworks') },
  { name: 'Citrix',     logo: SI('citrix') },
  { name: 'Fortinet',   logo: SI('fortinet') },
  { name: 'CheckPoint', logo: SI('checkpointsoftwaretechnologies') },
  { name: 'Proxmox',    logo: SI('proxmox') },
  { name: 'XenServer',  logo: 'https://www.xenserver.com/content/dam/xenserver/images/xenserver-full-color-rgb.svg', mono: false },
  { name: 'Veeam',      logo: SI('veeam') },
  { name: 'Acronis',    logo: SI('acronis') },
  { name: 'NetScaler',  logo: 'https://bpsme.com/wp-content/uploads/2016/06/NSLogo.png', mono: false },
  { name: 'Microsoft',  logo: SI('microsoft') },
  { name: 'Cloudflare', logo: SI('cloudflare') },
];

const mspIcon = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>`;
const swIcon  = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>`;
const rndIcon = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>`;
const msIcon  = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="8" height="8" rx="1"/><rect x="13" y="3" width="8" height="8" rx="1"/><rect x="3" y="13" width="8" height="8" rx="1"/><rect x="13" y="13" width="8" height="8" rx="1"/></svg>`;
---

<Base title="Ana Sayfa" description="GİTA Teknoloji – Geleceği Planlayan Stratejik Çözüm Ortağınız. MSP, yazılım danışmanlığı ve altyapı çözümleri." lang={lang}>
  <Nav lang={lang} currentPath={currentPath} />

  <main id="main-content">
    <HeroSection lang={lang} />

    <!-- Hizmetler Özeti -->
    <section class="section" aria-labelledby="home-services-title">
      <div class="container">
        <div class="section-title-group reveal">
          <span class="section-label">{t('nav.services')}</span>
          <h2 id="home-services-title">{t('services.title')}</h2>
          <p>{t('services.subtitle')}</p>
        </div>
        <div class="cards-grid cards-grid--4">
          <ServiceCard
            icon={mspIcon}
            title={t('services.msp.title')}
            description={t('services.msp.intro')}
            href={`/${lang}/hizmetler#msp`}
            image="/images/card-msp.jpeg"
          />
          <ServiceCard
            icon={swIcon}
            title={t('services.software.title')}
            description={t('services.software.intro')}
            href={`/${lang}/hizmetler#yazilim`}
            image="/images/card-software.jpeg"
          />
          <ServiceCard
            icon={rndIcon}
            title={t('services.rnd.title')}
            description={t('services.rnd.intro')}
            href={`/${lang}/hizmetler#arge`}
            image="/images/card-rnd.jpeg"
          />
          <ServiceCard
            icon={msIcon}
            title={t('services.msalliance.title')}
            description={t('services.msalliance.intro')}
            href={`/${lang}/hizmetler#ms-alliance`}
          />
        </div>
      </div>
    </section>

    <!-- Çözümler Özeti -->
    <section class="section section--alt" aria-labelledby="home-solutions-title">
      <div class="container">
        <div class="section-title-group reveal">
          <span class="section-label">{t('nav.solutions')}</span>
          <h2 id="home-solutions-title">{t('solutions.title')}</h2>
          <p>{t('solutions.subtitle')}</p>
        </div>
        <div class="cards-grid cards-grid--4">
          <SolutionCard
            title={t('solutions.network.title')}
            description={t('solutions.network.intro')}
            items={[t('solutions.network.wired.title'), t('solutions.network.sdwan.title'), t('solutions.network.waf.title')]}
            image="/images/card-network.jpeg"
            href={`/${lang}/cozumler#kurumsal-ag`}
          />
          <SolutionCard
            title={t('solutions.systems.title')}
            description={t('solutions.systems.intro')}
            items={[t('solutions.systems.server.title'), t('solutions.systems.cloud.title'), t('solutions.systems.devops.title')]}
            image="/images/card-enterprise.jpeg"
            href={`/${lang}/cozumler#sistem`}
          />
          <SolutionCard
            title={t('solutions.cloudflare.title')}
            description={t('solutions.cloudflare.intro')}
            items={[t('solutions.cloudflare.workers.title'), t('solutions.cloudflare.r2.title'), t('solutions.cloudflare.cdn.title')]}
            image="/images/banner-cloudflare.jpeg"
            href={`/${lang}/cozumler#cloudflare`}
          />
          <SolutionCard
            title={t('solutions.security.title')}
            description={t('solutions.security.intro')}
            items={[t('solutions.security.network.title'), t('solutions.security.mdm.title'), t('solutions.security.edr.title')]}
            image="/images/card-cybersecurity.jpeg"
            href={`/${lang}/cozumler#siber-guvenlik`}
          />
          <SolutionCard
            title={t('solutions.infrasoftware.title')}
            description={t('solutions.infrasoftware.intro')}
            items={[t('solutions.infrasoftware.cluster.title'), t('solutions.infrasoftware.sdwan.title'), t('solutions.infrasoftware.storage.title')]}
            image="/images/banner-infra-software.jpeg"
            href={`/${lang}/cozumler#altyapi-yazilim`}
          />
          <SolutionCard
            title={t('solutions.ai.title')}
            description={t('solutions.ai.intro')}
            items={[t('solutions.ai.predictive.title'), t('solutions.ai.anomaly.title'), t('solutions.ai.automation.title')]}
            image="/images/banner-ai-ml.jpeg"
            href={`/${lang}/cozumler#ai-ml`}
          />
          <SolutionCard
            title={t('solutions.lowvoltage.title')}
            description={t('solutions.lowvoltage.intro')}
            items={[t('solutions.lowvoltage.security.title'), t('solutions.lowvoltage.fire.title'), t('solutions.lowvoltage.data.title')]}
            image="/images/card-cabling.jpeg"
            href={`/${lang}/cozumler#zayif-akim`}
          />
        </div>
      </div>
    </section>

    <!-- Özel Yazılımlar Teaser -->
    <section class="section" aria-labelledby="home-products-title">
      <div class="container products-teaser">
        <div class="products-teaser__text reveal">
          <span class="section-label">{t('nav.products')}</span>
          <h2 id="home-products-title">{t('products.title')}</h2>
          <p>{t('products.subtitle')}</p>
          <a href={`/${lang}/urunler`} class="btn-primary" style="margin-top:1.5rem">
            {lang === 'tr' ? 'Tüm Ürünleri Keşfet' : 'Explore Products'}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
        <ul class="products-teaser__list reveal">
          {['Passeidon', 'Zabbix & Grafana', 'Proxmox + Citrix XenServer', 'Prometheus', 'GİTA QR Yoklama'].map(p => (
            <li class="products-teaser__item">
              <span class="products-teaser__dot" aria-hidden="true"></span>
              {p}
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- Çözüm Ortakları -->
    <section class="section section--alt" aria-labelledby="home-partners-title">
      <div class="container">
        <div class="section-title-group reveal">
          <span class="section-label">{t('nav.partners')}</span>
          <h2 id="home-partners-title">{t('partners.title')}</h2>
          <p>{t('partners.subtitle')}</p>
        </div>
        <PartnerGrid partners={partners} />
      </div>
    </section>

    <!-- CTA Banner -->
    <section class="section cta-banner" aria-labelledby="home-cta-title">
      <div class="container cta-banner__inner reveal">
        <div>
          <h2 id="home-cta-title">{t('home.cta.title')}</h2>
          <p>{t('home.cta.sub')}</p>
        </div>
        <a href={`/${lang}/iletisim`} class="btn-primary cta-banner__btn">{t('home.cta.button')}</a>
      </div>
    </section>
  </main>

  <Footer lang={lang} />
</Base>

<style>
  .cards-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .cards-grid--4 { grid-template-columns: repeat(4, 1fr); }

  .products-teaser {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  .products-teaser__text p { color: var(--color-text-muted); margin-top: 0.75rem; }
  .products-teaser__list { list-style: none; display: flex; flex-direction: column; gap: 1rem; }
  .products-teaser__item {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-family: 'Inter', sans-serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-text-muted);
    padding: 1rem 1.25rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-bg-2);
    transition: color var(--transition), border-color var(--transition);
  }
  .products-teaser__item:hover { color: var(--color-teal); border-color: rgba(0,200,200,0.3); }
  .products-teaser__dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: var(--color-teal); flex-shrink: 0;
  }

  .cta-banner { background: linear-gradient(135deg, rgba(5,13,26,0.80), rgba(10,95,214,0.75)), url('/images/bg-tech-office.jpeg') center/cover no-repeat; border-top: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border); }
  .cta-banner__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }
  .cta-banner__inner h2 { font-size: clamp(1.4rem, 3vw, 2rem); }
  .cta-banner__inner p { color: var(--color-text-muted); margin-top: 0.5rem; }
  .cta-banner__btn { flex-shrink: 0; }

  @media (max-width: 1024px) { .cards-grid--4 { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 768px) {
    .cards-grid { grid-template-columns: 1fr; }
    .cards-grid--4 { grid-template-columns: 1fr; }
    .products-teaser { grid-template-columns: 1fr; gap: 2rem; }
    .cta-banner__inner { flex-direction: column; align-items: flex-start; }
  }
</style>
