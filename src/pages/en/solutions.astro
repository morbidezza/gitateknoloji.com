---
export const prerender = true;
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import SolutionCard from '../../components/SolutionCard.astro';
import { useTranslations } from '../../i18n/utils';

const lang = 'en';
const t = useTranslations(lang);
const currentPath = Astro.url.pathname;

const anchors = [
  { id: 'network',          label: t('solutions.network.title') },
  { id: 'systems',          label: t('solutions.systems.title') },
  { id: 'cloudflare',       label: 'Cloudflare' },
  { id: 'cyber-security',   label: t('solutions.security.title') },
  { id: 'infra-software',   label: t('solutions.infrasoftware.title') },
  { id: 'ai-ml',            label: t('solutions.ai.title') },
  { id: 'low-voltage',      label: t('solutions.lowvoltage.title') },
];
---

<Base title={t('nav.solutions')} description="GITA Teknoloji solutions: low voltage, network, systems, cyber security, infrastructure software and AI." lang={lang}>
  <Nav lang={lang} currentPath={currentPath} />

  <main id="main-content">
    <section class="page-hero">
      <div class="container page-hero__inner">
        <h1 class="page-title">{t('solutions.title')}</h1>
        <p class="page-hero__sub">{t('solutions.subtitle')}</p>
      </div>
    </section>

    <div class="solutions-layout container">
      <aside class="solutions-sidebar" aria-label="Solution categories">
        <nav class="sidebar-nav">
          {anchors.map(a => (
            <a href={`#${a.id}`} class="sidebar-nav__link">{a.label}</a>
          ))}
        </nav>
      </aside>

      <div class="solutions-content">
        <section id="network" class="sol-section sol-section--bg" style="background-image: url('/images/card-network.jpeg');" aria-labelledby="network-title">
          <div class="sol-section__header reveal">
            <span class="section-label">{t('solutions.network.title')}</span>
            <h2 id="network-title">{t('solutions.network.title')}</h2>
            <p>{t('solutions.network.intro')}</p>
          </div>
          <div class="sol-cards reveal">
            <SolutionCard title={t('solutions.network.wired.title')} description={t('solutions.network.wired.intro')} items={[t('solutions.network.wired.switching'), t('solutions.network.wired.wireless'), t('solutions.network.wired.management')]} image="/images/card-network.jpeg" />
            <SolutionCard title={t('solutions.network.sdwan.title')} description={t('solutions.network.sdwan.intro')} items={[t('solutions.network.sdwan.traffic'), t('solutions.network.sdwan.central'), t('solutions.network.sdwan.secure')]} image="/images/card-network-alt.jpeg" />
            <SolutionCard title={t('solutions.network.waf.title')}   description={t('solutions.network.waf.intro')}   items={[t('solutions.network.waf.lb'), t('solutions.network.waf.waf')]} />
          </div>
        </section>

        <section id="systems" class="sol-section sol-section--bg" style="background-image: url('/images/bg-server-room.jpeg');" aria-labelledby="systems-title">
          <div class="sol-section__header reveal">
            <span class="section-label">{t('solutions.systems.title')}</span>
            <h2 id="systems-title">{t('solutions.systems.title')}</h2>
            <p>{t('solutions.systems.intro')}</p>
          </div>
          <div class="sol-cards sol-cards--wide reveal">
            {[
              { title: t('solutions.systems.server.title'),  body: t('solutions.systems.server.body') },
              { title: t('solutions.systems.hci.title'),     body: t('solutions.systems.hci.body') },
              { title: t('solutions.systems.cloud.title'),   body: t('solutions.systems.cloud.body') },
              { title: t('solutions.systems.vdi.title'),     body: t('solutions.systems.vdi.body') },
              { title: t('solutions.systems.backup.title'),  body: t('solutions.systems.backup.body') },
              { title: t('solutions.systems.dr.title'),      body: t('solutions.systems.dr.body') },
              { title: t('solutions.systems.linux.title'),   body: t('solutions.systems.linux.body') },
              { title: t('solutions.systems.devops.title'),  body: t('solutions.systems.devops.body') },
            ].map(item => (<SolutionCard title={item.title} description={item.body} items={[]} />))}
          </div>
        </section>

        <section id="cloudflare" class="sol-section" aria-labelledby="cloudflare-title">
          <div class="sol-section__header reveal">
            <h2 id="cloudflare-title">{t('solutions.cloudflare.title')}</h2>
            <p>{t('solutions.cloudflare.intro')}</p>
          </div>
          <div class="sol-cards reveal">
            <SolutionCard title={t('solutions.cloudflare.workers.title')} description={t('solutions.cloudflare.workers.body')} items={[]} />
            <SolutionCard title={t('solutions.cloudflare.kv.title')}      description={t('solutions.cloudflare.kv.body')}      items={[]} />
            <SolutionCard title={t('solutions.cloudflare.r2.title')}      description={t('solutions.cloudflare.r2.body')}      items={[]} />
            <SolutionCard title={t('solutions.cloudflare.cdn.title')}     description={t('solutions.cloudflare.cdn.body')}     items={[]} />
          </div>
        </section>

        <section id="cyber-security" class="sol-section sol-section--bg" style="background-image: url('/images/bg-cyber-shield.jpeg');" aria-labelledby="cyber-title">
          <div class="sol-section__header reveal">
            <span class="section-label">{t('solutions.security.title')}</span>
            <h2 id="cyber-title">{t('solutions.security.title')}</h2>
            <p>{t('solutions.security.intro')}</p>
          </div>
          <div class="sol-cards reveal">
            <SolutionCard title={t('solutions.security.network.title')} description={t('solutions.security.network.body')} items={[]} image="/images/card-cybersecurity.jpeg" />
            <SolutionCard title={t('solutions.security.mdm.title')}     description={t('solutions.security.mdm.body')}     items={[]} />
            <SolutionCard title={t('solutions.security.dlp.title')}     description={t('solutions.security.dlp.body')}     items={[]} />
            <SolutionCard title={t('solutions.security.edr.title')}     description={t('solutions.security.edr.body')}     items={[]} />
          </div>
        </section>

        <section id="infra-software" class="sol-section" aria-labelledby="infra-title">
          <div class="sol-section__header reveal">
            <span class="section-label">{t('solutions.infrasoftware.title')}</span>
            <h2 id="infra-title">{t('solutions.infrasoftware.title')}</h2>
            <p>{t('solutions.infrasoftware.intro')}</p>
          </div>
          <div class="sol-cards reveal">
            <SolutionCard title={t('solutions.infrasoftware.cluster.title')} description={t('solutions.infrasoftware.cluster.body')} items={[]} />
            <SolutionCard title={t('solutions.infrasoftware.sdwan.title')}   description={t('solutions.infrasoftware.sdwan.body')}   items={[]} />
            <SolutionCard title={t('solutions.infrasoftware.storage.title')} description={t('solutions.infrasoftware.storage.body')} items={[]} />
            <SolutionCard title={t('solutions.infrasoftware.custom.title')}  description={t('solutions.infrasoftware.custom.body')}  items={[]} />
          </div>
        </section>

        <section id="ai-ml" class="sol-section sol-section--bg" style="background-image: url('/images/bg-brain-circuit.jpeg');" aria-labelledby="ai-title">
          <div class="sol-section__header reveal">
            <span class="section-label">{t('solutions.ai.title')}</span>
            <h2 id="ai-title">{t('solutions.ai.title')}</h2>
            <p>{t('solutions.ai.intro')}</p>
          </div>
          <div class="sol-cards reveal">
            <SolutionCard title={t('solutions.ai.predictive.title')} description={t('solutions.ai.predictive.body')} items={[]} />
            <SolutionCard title={t('solutions.ai.anomaly.title')}    description={t('solutions.ai.anomaly.body')}    items={[]} />
            <SolutionCard title={t('solutions.ai.data.title')}       description={t('solutions.ai.data.body')}       items={[]} />
            <SolutionCard title={t('solutions.ai.automation.title')} description={t('solutions.ai.automation.body')} items={[]} />
          </div>
        </section>

        <section id="low-voltage" class="sol-section" aria-labelledby="low-voltage-title">
          <div class="sol-section__header reveal">
            <span class="section-label">{t('solutions.lowvoltage.title')}</span>
            <h2 id="low-voltage-title">{t('solutions.lowvoltage.title')}</h2>
            <p>{t('solutions.lowvoltage.intro')}</p>
          </div>
          <div class="sol-cards reveal">
            <SolutionCard title={t('solutions.lowvoltage.security.title')} description={t('solutions.lowvoltage.security.intro')} items={[t('solutions.lowvoltage.security.cctv'), t('solutions.lowvoltage.security.access'), t('solutions.lowvoltage.security.announcement'), t('solutions.lowvoltage.security.integration')]} image="/images/card-cabling.jpeg" />
            <SolutionCard title={t('solutions.lowvoltage.fire.title')}     description={t('solutions.lowvoltage.fire.intro')}     items={[t('solutions.lowvoltage.fire.compliance'), t('solutions.lowvoltage.fire.detection'), t('solutions.lowvoltage.fire.suppression'), t('solutions.lowvoltage.fire.e2e')]} />
            <SolutionCard title={t('solutions.lowvoltage.data.title')}     description={t('solutions.lowvoltage.data.intro')}     items={[t('solutions.lowvoltage.data.design'), t('solutions.lowvoltage.data.quality'), t('solutions.lowvoltage.data.cert'), t('solutions.lowvoltage.data.sustainable')]} />
          </div>
        </section>
      </div>
    </div>
  </main>

  <Footer lang={lang} />
</Base>

<style>
  .page-hero { padding: 7rem 0 4rem; background: transparent; border-bottom: none; position: relative; background-image: url('/images/hero-solutions.jpeg'); background-size: cover; background-position: center; }
  .page-hero::before { content: ''; position: absolute; inset: 0; background: linear-gradient(to bottom, rgba(5,13,26,0.45), rgba(5,13,26,0.85)); z-index: 0; }
  .page-hero__inner { position: relative; z-index: 1; }
  .page-hero__inner { display: flex; flex-direction: column; gap: 0.5rem; }
  .page-hero__sub { color: var(--color-text-muted); font-size: 1.1rem; max-width: 60ch; margin-top: 0.5rem; }
  .solutions-layout { display: grid; grid-template-columns: 220px 1fr; gap: 3rem; padding-top: 3rem; padding-bottom: 3rem; align-items: start; }
  .solutions-sidebar { position: sticky; top: 90px; }
  .sidebar-nav { display: flex; flex-direction: column; gap: 0.25rem; }
  .sidebar-nav__link { display: block; padding: 0.6rem 1rem; font-size: 0.85rem; font-weight: 500; color: var(--color-text-muted); border-left: 2px solid var(--color-border); transition: color var(--transition), border-color var(--transition); line-height: 1.4; }
  .sidebar-nav__link:hover { color: var(--color-teal); border-left-color: var(--color-teal); }
  .sol-section { padding: 3rem 0; border-bottom: 1px solid var(--color-border); }
  .sol-section:last-child { border-bottom: none; }
  .sol-section--bg { position: relative; background-size: cover; background-position: center; }
  .sol-section--bg::before { content: ''; position: absolute; inset: 0; background: rgba(5, 13, 26, 0.90); pointer-events: none; }
  .sol-section--bg > * { position: relative; z-index: 1; }
  .sol-section__header { margin-bottom: 2rem; }
  .sol-section__header h2 { margin: 0.25rem 0 0.75rem; }
  .sol-section__header p { color: var(--color-text-muted); font-size: 0.95rem; max-width: 70ch; }
  .sol-cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; }
  .sol-cards--wide { grid-template-columns: repeat(4, 1fr); }
  @media (max-width: 1024px) { .solutions-layout { grid-template-columns: 1fr; } .solutions-sidebar { position: static; } .sidebar-nav { flex-direction: row; flex-wrap: wrap; gap: 0.5rem; } .sidebar-nav__link { border-left: none; border: 1px solid var(--color-border); border-radius: var(--radius-sm); padding: 0.4rem 0.75rem; font-size: 0.8rem; } .sol-cards--wide { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 768px) { .sol-cards, .sol-cards--wide { grid-template-columns: 1fr; } }
</style>
