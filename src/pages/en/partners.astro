---
export const prerender = true;
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import PartnerGrid from '../../components/PartnerGrid.astro';
import { useTranslations } from '../../i18n/utils';

const lang = 'en';
const t = useTranslations(lang);
const currentPath = Astro.url.pathname;

const SI = (slug: string) => `https://cdn.simpleicons.org/${slug}/ffffff`;

const partners = [
  { name: 'HPE',          logo: SI('hewlettpackardenterprise') },
  { name: 'Dell',         logo: SI('dell') },
  { name: 'IBM',          logo: SI('ibm') },
  { name: 'Cisco',        logo: SI('cisco') },
  { name: 'Juniper',      logo: SI('junipernetworks') },
  { name: 'Citrix',       logo: SI('citrix') },
  { name: 'Fortinet',     logo: SI('fortinet') },
  { name: 'CheckPoint',   logo: SI('checkpointsoftwaretechnologies') },
  { name: 'Proxmox',      logo: SI('proxmox') },
  { name: 'VMware',       logo: SI('vmware') },
  { name: 'Veeam',        logo: SI('veeam') },
  { name: 'Acronis',      logo: SI('acronis') },
  { name: 'Microsoft',    logo: SI('microsoft') },
  { name: 'Azure',        logo: SI('microsoftazure') },
  { name: 'AWS',          logo: SI('amazonaws') },
  { name: 'Cloudflare',   logo: SI('cloudflare') },
  { name: 'XenServer',    logo: 'https://www.xenserver.com/content/dam/xenserver/images/xenserver-full-color-rgb.svg', mono: false },
  { name: 'NetScaler',    logo: 'https://bpsme.com/wp-content/uploads/2016/06/NSLogo.png', mono: false },
  { name: 'LogSenth',     logo: 'https://www.logsenth.com/assets/uploads/logsenth/logo-2.png', mono: false },
];
---

<Base title={t('nav.partners')} description="GITA Teknoloji solution partners: HPE, Proxmox, Cloudflare, Veeam, Microsoft, Azure, AWS and more." lang={lang}>
  <Nav lang={lang} currentPath={currentPath} />

  <main id="main-content">
    <section class="page-hero">
      <div class="container page-hero__inner">
        <h1 class="page-title">{t('partners.title')}</h1>
        <p class="page-hero__sub">{t('partners.subtitle')}</p>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <PartnerGrid partners={partners} />
      </div>
    </section>
  </main>

  <Footer lang={lang} />
</Base>

<style>
  .page-hero { padding: 7rem 0 4rem; background: transparent; border-bottom: none; position: relative; background-image: url('/images/hero-partners.jpeg'); background-size: cover; background-position: center; }
  .page-hero::before { content: ''; position: absolute; inset: 0; background: linear-gradient(to bottom, rgba(5,13,26,0.45), rgba(5,13,26,0.85)); z-index: 0; }
  .page-hero__inner { position: relative; z-index: 1; }
  .page-hero__inner { display: flex; flex-direction: column; gap: 0.5rem; }
  .page-hero__sub { color: var(--color-text-muted); font-size: 1.1rem; max-width: 60ch; margin-top: 0.5rem; }
</style>
