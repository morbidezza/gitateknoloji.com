---
export const prerender = true;
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { useTranslations } from '../../i18n/utils';

const lang = 'en';
const t = useTranslations(lang);
const currentPath = Astro.url.pathname;
---

<Base title={t('nav.about')} description="About GITA Teknoloji. Over 20 years of IT expertise, MSP model and strategic technology partnership." lang={lang}>
  <Nav lang={lang} currentPath={currentPath} />

  <main id="main-content">
    <section class="page-hero">
      <div class="container page-hero__inner">
        <h1 class="page-title">{t('about.title')}</h1>
        <p class="page-hero__sub">{t('about.subtitle')}</p>
      </div>
    </section>

    <section class="section" aria-labelledby="about-story-title">
      <div class="container about-story">
        <div class="about-story__text reveal">
          <span class="section-label">{t('about.strategy.title')}</span>
          <h2 id="about-story-title">{t('about.title')}</h2>
          <p class="about-intro">{t('about.intro')}</p>
          <p style="margin-top:1rem;">{t('about.strategy.body')}</p>
          <p style="margin-top:1rem;">{t('about.closing')}</p>
        </div>
        <div class="about-story__stats reveal">
          {[
            { label: t('about.stat.experience'), sub: null,                    img: '/images/about-stat-experience.jpeg' },
            { label: t('about.stat.msp'),        sub: t('about.stat.msp.sub'), img: '/images/about-stat-msp.jpeg' },
            { label: t('about.stat.customer'),   sub: null,                    img: '/images/about-stat-customer.jpeg' },
          ].map(s => (
            <div class="stat-card">
              <img src={s.img} alt={s.label} class="stat-card__img" loading="lazy" />
              <span class="stat-card__label">{s.label}</span>
              {s.sub && <span class="stat-card__sub">{s.sub}</span>}
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="section section--alt" aria-labelledby="about-strategy-title">
      <div class="container">
        <div class="section-title-group reveal">
          <span class="section-label">Our Approach</span>
          <h2 id="about-strategy-title">{t('about.strategy.title')}</h2>
        </div>
        <div class="approach-rows reveal">
          {[
            { title: 'Holistic Engineering', body: 'We simplify complex infrastructure challenges with our holistic engineering approach, developing strategic solutions tailored to each specific business need.' },
            { title: 'Efficiency-Driven Guidance', body: 'We build a sustainable technological architecture with complementary software and original projects that increase business efficiency.' },
            { title: 'Proactive Technology Partnership', body: 'We position ourselves not just as a service provider, but as a strategic technology partner in businesses\' digitalization journey.' },
          ].map((item, i) => (
            <div class="approach-row">
              <div>
                <h3 class="approach-row__title">{item.title}</h3>
                <p class="approach-row__body">{item.body}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="section" aria-labelledby="about-vision-title">
      <div class="container">
        <div class="section-title-group reveal">
          <span class="section-label">Vision</span>
          <h2 id="about-vision-title">{t('about.vision.title')}</h2>
        </div>
        <div class="vision-cards reveal">
          {[
            { title: t('about.vision.integrated.title'), body: t('about.vision.integrated.body') },
            { title: t('about.vision.software.title'),   body: t('about.vision.software.body') },
            { title: t('about.vision.msp.title'),        body: t('about.vision.msp.body') },
          ].map(card => (
            <div class="vision-card">
              <span class="vision-card__accent" aria-hidden="true"></span>
              <h3 class="vision-card__title">{card.title}</h3>
              <p class="vision-card__body">{card.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  </main>

  <Footer lang={lang} />
</Base>

<style>
  .page-hero { padding: 7rem 0 4rem; background: transparent; border-bottom: none; }
  .page-hero__inner { display: flex; flex-direction: column; gap: 0.5rem; }
  .page-hero__sub { color: var(--color-text-muted); font-size: 1.1rem; max-width: 60ch; margin-top: 0.5rem; }
  .about-story { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: start; }
  .about-intro { color: #ffffff; font-size: 1.05rem; line-height: 1.8; }
  .about-story__text p { color: #ffffff; }
  .stat-card__sub { font-size: 0.78rem; color: var(--color-text-muted); margin-top: 0.15rem; }
  .about-story__stats { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .stat-card { background: var(--color-bg-2); border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: 1.5rem; display: flex; flex-direction: column; gap: 0.5rem; transition: border-color var(--transition), box-shadow var(--transition); overflow: hidden; }
  .stat-card__img { width: calc(100% + 3rem); margin: -1.5rem -1.5rem 0.75rem; aspect-ratio: 16/9; object-fit: cover; border-radius: var(--radius-md) var(--radius-md) 0 0; }
  .stat-card:hover { border-color: rgba(0,200,200,0.3); box-shadow: 0 0 24px var(--color-glow); }
.stat-card__label { font-family: 'Inter', sans-serif; font-weight: 700; font-size: 0.95rem; }
  .approach-rows { display: flex; flex-direction: column; gap: 1.5rem; }
  .approach-row { display: flex; gap: 2rem; align-items: flex-start; padding: 1.75rem 2rem; background: var(--color-bg-2); border: 1px solid var(--color-border); border-radius: var(--radius-md); transition: border-color var(--transition); }
  .approach-row:hover { border-color: rgba(0,200,200,0.3); }
.approach-row__title { font-size: 1.1rem; margin-bottom: 0.4rem; }
  .approach-row__body  { color: var(--color-text-muted); font-size: 0.93rem; }
  .vision-cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
  .vision-card { position: relative; background: var(--color-bg-2); border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: 2rem; overflow: hidden; transition: transform var(--transition), box-shadow var(--transition), border-color var(--transition); }
  .vision-card:hover { transform: translateY(-4px); box-shadow: 0 0 32px var(--color-glow); border-color: rgba(0,200,200,0.3); }
  .vision-card__accent { position: absolute; top: 0; left: 0; right: 0; height: 3px; background: linear-gradient(90deg, var(--color-teal), var(--color-blue)); border-radius: var(--radius-md) var(--radius-md) 0 0; }
  .vision-card__title { font-size: 1.05rem; margin-bottom: 0.75rem; }
  .vision-card__body  { color: var(--color-text-muted); font-size: 0.92rem; line-height: 1.65; }
  @media (max-width: 900px) { .about-story { grid-template-columns: 1fr; gap: 2.5rem; } .vision-cards { grid-template-columns: 1fr; } }
  @media (max-width: 600px) { .about-story__stats { grid-template-columns: 1fr; } .approach-row { flex-direction: column; gap: 0.75rem; } }
</style>
